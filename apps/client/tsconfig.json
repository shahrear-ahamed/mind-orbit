{
  "extends": "@mindorbit/typescript-config/react.json",
  "include": ["src"],
  "compilerOptions": {
    "types": ["vite/client"],

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@mindorbit/ui/*": ["../../packages/ui/src/*"]
    }
  }
}
